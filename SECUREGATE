<div class="toast" id="toast"></div>

<script>
const STORE_KEY='sg-registros';
const PINS_KEY='sg-pins';
let R=[],nid=1,cv='dashboard';
let camStream=null,camTarget='f';
let photoData={f:null,m:null};
let lastHash='',lastPinHash='';
let activePasteTarget='f';
let currentRole=null;
let selectedRole='user';
let pinInput='';
let PINS={user:'1234',admin:'9999'};

// ── LOGIN ─────────────────────────────────────────────────
function selectRole(r){
  selectedRole=r;
  document.getElementById('rb-user').classList.toggle('selected',r==='user');
  document.getElementById('rb-admin').classList.toggle('selected',r==='admin');
  pinInput='';updatePinDisplay();
  document.getElementById('loginErr').style.display='none';
}
function pinKey(k){if(pinInput.length<4){pinInput+=k;updatePinDisplay();if(pinInput.length===4)setTimeout(pinEnter,120);}}
function pinDel(){pinInput=pinInput.slice(0,-1);updatePinDisplay();}
function updatePinDisplay(){
  for(let i=0;i<4;i++)document.getElementById('pd'+i).classList.toggle('filled',i<pinInput.length);
}
function pinEnter(){
  if(pinInput===PINS[selectedRole]){
    currentRole=selectedRole;
    document.getElementById('loginScreen').style.display='none';
    document.getElementById('appScreen').style.display='block';
    applyRole();rd();
  } else {
    document.getElementById('loginErr').style.display='block';
    pinInput='';updatePinDisplay();
    setTimeout(()=>document.getElementById('loginErr').style.display='none',2000);
  }
}
function applyRole(){
  const isAdmin=currentRole==='admin';
  document.querySelectorAll('.admin-only').forEach(el=>el.style.display=isAdmin?'':'none');
  const badge=document.getElementById('sessionBadge');
  badge.textContent=isAdmin?'🔧 ADMIN':'🛡️ PUERTA PRINCIPAL';
  badge.className='session-badge'+(isAdmin?' admin':'');
}
function logout(){currentRole=null;pinInput='';updatePinDisplay();selectedRole='user';selectRole('user');document.getElementById('appScreen').style.display='none';document.getElementById('loginScreen').style.display='block';}

// ── PINS STORAGE ──────────────────────────────────────────
async function loadPins(){
  try{const r=await window.storage.get(PINS_KEY,true);if(r&&r.value)PINS=JSON.parse(r.value);}catch(e){}
}
async function savePins(){
  try{await window.storage.set(PINS_KEY,JSON.stringify(PINS),true);}catch(e){}
}
async function savePin(role){
  const val=document.getElementById(role==='user'?'pinUser':'pinAdmin').value.trim();
  if(val.length!==4||!/^\d{4}$/.test(val)){toast('El PIN debe tener exactamente 4 dígitos','err');return;}
  PINS[role]=val;
  await savePins();
  document.getElementById(role==='user'?'pinUser':'pinAdmin').value='';
  toast('PIN '+(role==='user'?'de Guardia':'de Admin')+' actualizado');
}

// ── SYNC ──────────────────────────────────────────────────
function setSyncDot(s){document.getElementById('sdot').className='sync-dot '+s;}
async function saveToStore(data){
  setSyncDot('syncing');
  try{await window.storage.set(STORE_KEY,JSON.stringify(data),true);setSyncDot('ok');}
  catch(e){setSyncDot('err');}
}
async function loadFromStore(){try{const r=await window.storage.get(STORE_KEY,true);if(r&&r.value)return JSON.parse(r.value);}catch(e){}return null;}
async function syncPoll(){
  try{
    const r=await window.storage.get(STORE_KEY,true);
    if(r&&r.value){const h=r.value.substring(0,80);if(h!==lastHash){lastHash=h;const p=JSON.parse(r.value);if(p&&p.records){R=p.records;nid=p.nid||R.length+1;if(cv==='dashboard')rd();if(cv==='historial')rh();if(cv==='admin')ra();}}setSyncDot('ok');}
    const rp=await window.storage.get(PINS_KEY,true);
    if(rp&&rp.value){const hp=rp.value.substring(0,40);if(hp!==lastPinHash){lastPinHash=hp;PINS=JSON.parse(rp.value);}}
  }catch(e){setSyncDot('err');}
}
async function init(){
  await loadPins();
  const data=await loadFromStore();
  if(data&&data.records&&data.records.length>0){R=data.records;nid=data.nid||R.length+1;}
  else{R=[{id:1,nombre:"Carlos Mendoza",doc:"V-12345678",tipo:"Visita",unidad:"Apartamentos Valle - 4B",placa:"ABC-123",motivo:"Invitado de Propietario",entrada:"2026-03-03T08:15:00",salida:"2026-03-03T10:30:00",estado:"Egresado",guardia:"Ramírez J.",obs:"",foto:null},{id:2,nombre:"Ana Lucía Torres",doc:"V-18765432",tipo:"Visita",unidad:"Apartamentos Valle Alto - 12A",placa:null,motivo:"Invitado de Propietario",entrada:"2026-03-03T10:00:00",salida:null,estado:"En Recinto",guardia:"González P.",obs:"",foto:null}];nid=3;await saveToStore({records:R,nid});}
  document.getElementById('loader').style.display='none';
  document.getElementById('loginScreen').style.display='block';
  setInterval(syncPoll,8000);
}

// ── CLOCK ─────────────────────────────────────────────────
setInterval(()=>{
  const n=new Date();
  document.getElementById('clock').textContent=n.toLocaleTimeString('es-VE',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  document.getElementById('date').textContent=n.toLocaleDateString('es-VE',{weekday:'short',day:'2-digit',month:'short'}).toUpperCase();
},1000);

// ── VISTAS ────────────────────────────────────────────────
function sv(v){
  if(v==='admin'&&currentRole!=='admin')return;
  cv=v;
  ['dashboard','registro','historial','admin'].forEach((x,i)=>{
    const el=document.getElementById('v'+x[0]);if(el)el.style.display=x===v?'block':'none';
    const nb=document.querySelectorAll('.nb')[i];if(nb)nb.classList.toggle('active',x===v);
  });
  if(v==='registro')activePasteTarget='f';
  if(v==='dashboard')rd();
  if(v==='historial')rh();
  if(v==='admin')ra();
}
function ft(d){if(!d)return'—';return new Date(d).toLocaleTimeString('es-VE',{hour:'2-digit',minute:'2-digit'});}
function fd(d){if(!d)return'—';return new Date(d).toLocaleDateString('es-VE',{day:'2-digit',month:'2-digit',year:'numeric'});}
function now(){return new Date().toISOString();}

function rd(){
  const hoy=new Date().toDateString(),en=R.filter(r=>r.estado==='En Recinto');
  document.getElementById('s1').textContent=en.length;
  document.getElementById('s2').textContent=R.filter(r=>new Date(r.entrada).toDateString()===hoy).length;
  document.getElementById('s3').textContent=R.filter(r=>r.salida&&new Date(r.salida).toDateString()===hoy).length;
  document.getElementById('s4').textContent=R.length;
  const tb=document.getElementById('tbd');
  if(!en.length){tb.innerHTML='<tr><td colspan="5" class="empty">No hay visitantes en recinto</td></tr>';return;}
  tb.innerHTML=en.map(r=>`<tr>
    <td style="color:#0f172a;font-weight:600">${r.nombre}</td>
    <td><span class="ttag">${r.tipo}</span></td>
    <td style="color:#64748b;font-size:9px">${r.unidad}</td>
    <td style="color:#0284c7">${ft(r.entrada)}</td>
    <td><div class="acts"><button class="bs" onclick="om('salida',${r.id})">EGRESO</button><button class="bg" onclick="om('ver',${r.id})">VER</button></div></td>
  </tr>`).join('');
}

function rh(){
  const q=(document.getElementById('si')?.value||'').toLowerCase();
  const fe=document.getElementById('fe')?.value||'Todos',fti=document.getElementById('fti')?.value||'Todos';
  const f=R.filter(r=>{const m=!q||r.nombre.toLowerCase().includes(q)||r.doc.includes(q)||(r.placa||'').toLowerCase().includes(q)||r.unidad.toLowerCase().includes(q);return m&&(fe==='Todos'||r.estado===fe)&&(fti==='Todos'||r.tipo===fti);}).sort((a,b)=>new Date(b.entrada)-new Date(a.entrada));
  document.getElementById('rc').textContent=f.length+' registro'+(f.length!==1?'s':'')+' encontrado'+(f.length!==1?'s':'');
  const tb=document.getElementById('tbh');
  if(!f.length){tb.innerHTML='<tr><td colspan="8" class="empty">Sin resultados</td></tr>';return;}
  tb.innerHTML=f.map(r=>`<tr>
    <td style="color:#94a3b8">#${r.id}</td>
    <td style="color:#0f172a;font-weight:600;font-size:10px">${r.nombre}</td>
    <td><span class="ttag">${r.tipo}</span></td>
    <td style="color:#0284c7;font-size:9px">${fd(r.entrada)}<br>${ft(r.entrada)}</td>
    <td style="color:${r.salida?'#7c3aed':'#94a3b8'};font-size:9px">${r.salida?fd(r.salida)+'<br>'+ft(r.salida):'—'}</td>
    <td>${r.foto?`<img src="${r.foto}" class="id-thumb" onclick="viewImg('${r.foto}')" title="Ver ID"/>`:'<span style="font-size:9px;color:#cbd5e1">—</span>'}</td>
    <td><span class="badge ${r.estado==='En Recinto'?'ben':'beg'}"><span class="bdot"></span>${r.estado==='En Recinto'?'Activo':'Egresado'}</span></td>
    <td><div class="acts">${r.estado==='En Recinto'?`<button class="bs" onclick="om('salida',${r.id})">EGRESO</button>`:''}<button class="bg" onclick="om('ver',${r.id})">VER</button></div></td>
  </tr>`).join('');
}

function ra(){
  const q=(document.getElementById('siadmin')?.value||'').toLowerCase();
  const f=R.filter(r=>!q||r.nombre.toLowerCase().includes(q)||r.doc.includes(q)).sort((a,b)=>new Date(b.entrada)-new Date(a.entrada));
  document.getElementById('rcadmin').textContent=f.length+' registros';
  const tb=document.getElementById('tbadmin');
  if(!f.length){tb.innerHTML='<tr><td colspan="6" class="empty">Sin resultados</td></tr>';return;}
  tb.innerHTML=f.map(r=>`<tr>
    <td style="color:#94a3b8">#${r.id}</td>
    <td style="color:#0f172a;font-weight:600;font-size:10px">${r.nombre}</td>
    <td><span class="ttag">${r.tipo}</span></td>
    <td style="color:#0284c7;font-size:9px">${fd(r.entrada)}<br>${ft(r.entrada)}</td>
    <td><span class="badge ${r.estado==='En Recinto'?'ben':'beg'}"><span class="bdot"></span>${r.estado==='En Recinto'?'Activo':'Egresado'}</span></td>
    <td><div class="acts">
      <button class="be" onclick="om('editar',${r.id})">✏️ EDITAR</button>
      <button class="bg" style="color:#dc2626;border-color:#fca5a5" onclick="eliminar(${r.id})">🗑</button>
    </div></td>
  </tr>`).join('');
}

// ── DRAG & DROP / PASTE ───────────────────────────────────
function dzDrag(e,t){e.preventDefault();document.getElementById('dz-'+t).classList.add('drag-over');activePasteTarget=t;}
function dzLeave(t){document.getElementById('dz-'+t).classList.remove('drag-over');}
function dzDrop(e,t){e.preventDefault();document.getElementById('dz-'+t).classList.remove('drag-over');const file=[...e.dataTransfer.files].find(f=>f.type.startsWith('image/'));if(file)readFileToPhoto(file,t);else toast('Solo se aceptan imágenes','err');}
function readFileToPhoto(file,target){const r=new FileReader();r.onload=e=>setPhoto(target,e.target.result);r.readAsDataURL(file);}
document.addEventListener('paste',e=>{const img=[...(e.clipboardData?.items||[])].find(i=>i.type.startsWith('image/'));if(img){e.preventDefault();readFileToPhoto(img.getAsFile(),activePasteTarget);}});
function setPhoto(target,data){
  photoData[target]=data;
  const ph=document.getElementById('dz-'+target+'-ph'),img=document.getElementById('dz-'+target+'-img'),clr=document.getElementById('dz-'+target+'-clr'),dz=document.getElementById('dz-'+target);
  if(ph)ph.style.display='none';if(img){img.src=data;img.style.display='block';}if(dz)dz.classList.add('has-img');if(clr)clr.style.display='block';
  toast('Foto cargada ✓');
}
function clearDz(target){
  photoData[target]=null;
  const ph=document.getElementById('dz-'+target+'-ph'),img=document.getElementById('dz-'+target+'-img'),clr=document.getElementById('dz-'+target+'-clr'),dz=document.getElementById('dz-'+target);
  if(ph)ph.style.display='block';if(img){img.src='';img.style.display='none';}if(dz)dz.classList.remove('has-img');if(clr)clr.style.display='none';
}

// ── CÁMARA ────────────────────────────────────────────────
function openCam(target){
  camTarget=target;activePasteTarget=target;
  if(!navigator.mediaDevices||!navigator.mediaDevices.getUserMedia){document.getElementById('camModal').classList.add('open');document.getElementById('camVideo').style.display='none';document.getElementById('camErr').style.display='block';return;}
  document.getElementById('camModal').classList.add('open');document.getElementById('camErr').style.display='none';document.getElementById('camVideo').style.display='block';
  navigator.mediaDevices.getUserMedia({video:{facingMode:{ideal:'environment'}},audio:false})
    .then(s=>{camStream=s;document.getElementById('camVideo').srcObject=s;})
    .catch(()=>navigator.mediaDevices.getUserMedia({video:true,audio:false}).then(s=>{camStream=s;document.getElementById('camVideo').srcObject=s;}).catch(()=>{document.getElementById('camVideo').style.display='none';document.getElementById('camErr').style.display='block';}));
}
function closeCam(){if(camStream){camStream.getTracks().forEach(t=>t.stop());camStream=null;}document.getElementById('camModal').classList.remove('open');}
function snapPhoto(){const v=document.getElementById('camVideo'),c=document.getElementById('camCanvas');if(!v.srcObject){closeCam();return;}c.width=v.videoWidth;c.height=v.videoHeight;c.getContext('2d').drawImage(v,0,0);closeCam();setPhoto(camTarget,c.toDataURL('image/jpeg',0.85));}
function viewImg(src){document.getElementById('imgBig').src=src;document.getElementById('imgModal').classList.add('open');}

function photoWidget(target){
  return`<div class="photo-sec"><span class="photo-lbl">FOTO DEL ID</span>
    <div class="drop-zone" id="dz-${target}" ondragover="dzDrag(event,'${target}')" ondragleave="dzLeave('${target}')" ondrop="dzDrop(event,'${target}')">
      <div id="dz-${target}-ph"><div class="pi">🪪</div><p><strong>Arrastra</strong> la foto aquí<br>o <strong>Ctrl+V</strong> para pegar</p>
        <button class="cam-btn" onclick="openCam('${target}')">📷 Usar Cámara</button>
        <div class="hint">Compatible con Chromebook · PC · Móvil</div>
      </div>
      <img id="dz-${target}-img" class="drop-preview"/>
      <button class="drop-clear" id="dz-${target}-clr" style="display:none" onclick="clearDz('${target}')">✕ Quitar</button>
    </div></div>`;
}

// ── MODAL ─────────────────────────────────────────────────
function om(mode,id){
  const r=R.find(x=>x.id===id);
  document.getElementById('mtit').textContent=mode==='entrada'?'🔑 NUEVO INGRESO':mode==='salida'?'🚪 REGISTRAR EGRESO':mode==='editar'?'✏️ EDITAR REGISTRO':'📄 DETALLE';
  photoData.m=null;

  if(mode==='entrada'){
    document.getElementById('mbody').innerHTML=`
      <div class="frow"><div class="fg"><label>NOMBRE *</label><input id="mn" placeholder="Nombre y apellido"/></div><div class="fg"><label>DOCUMENTO *</label><input id="md" placeholder="V-12345678"/></div></div>
      <div class="frow"><div class="fg"><label>TIPO</label><select id="mti"><option>Visita</option><option>Propietario</option><option>Residente</option><option>Proveedor/Servicio</option><option>Contratista Externo</option><option>Empleado</option><option>Otro</option></select></div><div class="fg"><label>PLACA</label><input id="mpl" placeholder="ABC-123"/></div></div>
      <div class="frow"><div class="fg"><label>TORRE / ÁREA *</label><select id="mtr"><option value="">Seleccionar...</option><option>Apartamentos Valle Alto</option><option>Apartamentos Valle</option><option>Villa Montaña</option><option>Villa Marina</option><option>Villa Playa</option><option>La Marina</option><option>Hotel Bannister</option><option>Administración HMS</option><option>Proyecto Bancalari</option><option>Otras</option></select></div><div class="fg"><label>NÚMERO DE LA PROPIEDAD</label><input id="mpi" placeholder="Ej. 4B"/></div></div>
      <div class="frow"><div class="fg"><label>RAZÓN DE ENTRADA</label><select id="mmo"><option value="">Seleccionar...</option><option>Acceso Frecuente Autorizado</option><option>Invitado de Propietario</option><option>Proveedor de Contratista</option><option>Proveedor del Hotel</option><option>Proveedor Marina</option><option>Proveedor de Condominio</option><option>Proveedor Proyecto Bancalari</option><option>Trabajos de Construcción</option><option>Trabajo de Mantenimiento</option><option>Reservación de Hotel</option><option>Reservación Independiente</option><option>Excursión Marina</option><option>Otros</option></select></div><div class="fg"><label>PUERTA PRINCIPAL</label><select id="mg"><option>Ramírez J.</option><option>González P.</option><option>Martínez L.</option><option>Rojas K.</option></select></div></div>
      ${photoWidget('m')}`;
    activePasteTarget='m';
    document.getElementById('mfoot').innerHTML=`<button class="bp" onclick="riModal()">✅ REGISTRAR INGRESO</button><button class="bc" onclick="cm()">CANCELAR</button>`;
  } else if(mode==='salida'&&r){
    document.getElementById('mbody').innerHTML=`
      <div class="ibox"><div style="font-size:14px;font-weight:700;margin-bottom:3px;color:#0f172a">${r.nombre}</div>
      <div style="font-size:10px;color:#64748b">${r.doc} · ${r.tipo}</div>
      <div style="font-size:10px;color:#64748b;margin-top:2px">${r.unidad}</div>
      <div style="font-size:10px;color:#0284c7;margin-top:5px">Ingresó: ${fd(r.entrada)} a las ${ft(r.entrada)}</div></div>
      <div class="cbox">⚠️ Se registrará la salida ahora. Estado cambiará a <strong>Egresado</strong>.</div>`;
    document.getElementById('mfoot').innerHTML=`<button class="bp" style="background:linear-gradient(135deg,#16a34a,#15803d)" onclick="reEgreso(${r.id})">🚪 CONFIRMAR EGRESO</button><button class="bc" onclick="cm()">CANCELAR</button>`;
  } else if(mode==='editar'&&r){
    document.getElementById('mbody').innerHTML=`
      <div class="frow"><div class="fg"><label>NOMBRE</label><input id="en" value="${r.nombre}"/></div><div class="fg"><label>DOCUMENTO</label><input id="ed" value="${r.doc}"/></div></div>
      <div class="frow"><div class="fg"><label>TIPO</label><select id="eti"><option ${r.tipo==='Visita'?'selected':''}>Visita</option><option ${r.tipo==='Propietario'?'selected':''}>Propietario</option><option ${r.tipo==='Residente'?'selected':''}>Residente</option><option ${r.tipo==='Proveedor/Servicio'?'selected':''}>Proveedor/Servicio</option><option ${r.tipo==='Contratista Externo'?'selected':''}>Contratista Externo</option><option ${r.tipo==='Empleado'?'selected':''}>Empleado</option><option ${r.tipo==='Otro'?'selected':''}>Otro</option></select></div><div class="fg"><label>PLACA</label><input id="epl" value="${r.placa||''}"/></div></div>
      <div class="frow"><div class="fg"><label>ESTADO</label><select id="est"><option ${r.estado==='En Recinto'?'selected':''}>En Recinto</option><option ${r.estado==='Egresado'?'selected':''}>Egresado</option></select></div><div class="fg"><label>PUERTA PRINCIPAL</label><input id="egu" value="${r.guardia}"/></div></div>
      <div class="fg"><label>OBSERVACIONES</label><textarea id="eobs">${r.obs||''}</textarea></div>`;
    document.getElementById('mfoot').innerHTML=`<button class="bp" onclick="guardarEdicion(${r.id})">💾 GUARDAR CAMBIOS</button><button class="bc" onclick="cm()">CANCELAR</button>`;
  } else if(mode==='ver'&&r){
    document.getElementById('mbody').innerHTML=`
    ${r.foto?`<div style="text-align:center;margin-bottom:12px"><img src="${r.foto}" style="max-height:120px;border-radius:8px;border:1px solid #e2e8f0;cursor:pointer" onclick="viewImg('${r.foto}')"/><div style="font-size:8px;color:#94a3b8;margin-top:3px">FOTO ID · toca para ampliar</div></div>`:'<div style="text-align:center;color:#cbd5e1;font-size:9px;margin-bottom:12px">Sin foto de ID</div>'}
    <div class="dgrid">${[['NOMBRE',r.nombre],['DOCUMENTO',r.doc],['TIPO',r.tipo],['UNIDAD',r.unidad],['PLACA',r.placa||'Sin vehículo'],['GUARDIA',r.guardia],['ENTRADA',fd(r.entrada)+' '+ft(r.entrada)],['SALIDA',r.salida?fd(r.salida)+' '+ft(r.salida):'Aún en recinto'],['RAZÓN',r.motivo||'—'],['ESTADO',r.estado]].map(([l,v])=>`<div class="di"><div class="dl">${l}</div><div class="dv">${v}</div></div>`).join('')}
    ${r.obs?`<div class="di" style="grid-column:1/-1"><div class="dl">OBSERVACIONES</div><div class="dv" style="font-weight:400;color:#64748b;font-size:10px">${r.obs}</div></div>`:''}</div>`;
    document.getElementById('mfoot').innerHTML=`<button class="bc" onclick="cm()">CERRAR</button>`;
  }
  document.getElementById('modal').classList.add('open');
}
function cm(){document.getElementById('modal').classList.remove('open');}

// ── CRUD ──────────────────────────────────────────────────
async function regIngreso(){
  const n=document.getElementById('fn').value.trim(),d=document.getElementById('fd').value.trim(),t=document.getElementById('ftr').value;
  if(!n||!d||!t){toast('Complete los campos obligatorios','err');return;}
  R.unshift({id:nid++,nombre:n,doc:d,tipo:document.getElementById('ft').value,unidad:t+(document.getElementById('fpi').value?' - '+document.getElementById('fpi').value:''),placa:document.getElementById('fp').value||null,motivo:document.getElementById('fm').value,entrada:now(),salida:null,estado:'En Recinto',guardia:document.getElementById('fg2').value,obs:document.getElementById('fo').value,foto:photoData.f});
  limpiar();await saveToStore({records:R,nid});toast('Ingreso registrado: '+n);rd();
}
async function riModal(){
  const n=document.getElementById('mn')?.value.trim(),d=document.getElementById('md')?.value.trim(),t=document.getElementById('mtr')?.value;
  if(!n||!d||!t){toast('Complete los campos obligatorios','err');return;}
  R.unshift({id:nid++,nombre:n,doc:d,tipo:document.getElementById('mti').value,unidad:t+(document.getElementById('mpi').value?' - '+document.getElementById('mpi').value:''),placa:document.getElementById('mpl').value||null,motivo:document.getElementById('mmo').value,entrada:now(),salida:null,estado:'En Recinto',guardia:document.getElementById('mg').value,obs:'',foto:photoData.m});
  cm();await saveToStore({records:R,nid});toast('Ingreso registrado: '+n);
  if(cv==='dashboard')rd();if(cv==='historial')rh();
}
async function reEgreso(id){
  R=R.map(r=>r.id===id?{...r,salida:now(),estado:'Egresado'}:r);
  cm();await saveToStore({records:R,nid});toast('Egreso registrado correctamente');
  if(cv==='dashboard')rd();if(cv==='historial')rh();
}
async function guardarEdicion(id){
  R=R.map(r=>r.id===id?{...r,nombre:document.getElementById('en').value.trim()||r.nombre,doc:document.getElementById('ed').value.trim()||r.doc,tipo:document.getElementById('eti').value,placa:document.getElementById('epl').value||null,estado:document.getElementById('est').value,salida:document.getElementById('est').value==='Egresado'&&!r.salida?now():r.salida,guardia:document.getElementById('egu').value,obs:document.getElementById('eobs').value}:r);
  cm();await saveToStore({records:R,nid});toast('Registro actualizado');
  if(cv==='admin')ra();if(cv==='dashboard')rd();if(cv==='historial')rh();
}
async function eliminar(id){
  if(!confirm('¿Eliminar este registro permanentemente?'))return;
  R=R.filter(r=>r.id!==id);
  await saveToStore({records:R,nid});toast('Registro eliminado');ra();
}
async function clearAll(){
  if(!confirm('¿Borrar TODOS los registros? Esta acción es irreversible.'))return;
  R=[];nid=1;await saveToStore({records:R,nid});toast('Todos los registros eliminados','err');ra();rd();
}
function limpiar(){
  ['fn','fd','fp','fpi','fo'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  ['ft','ftr','fg2','fm'].forEach(id=>{const e=document.getElementById(id);if(e)e.selectedIndex=0;});
  clearDz('f');
}
function toast(msg,type='suc'){
  const t=document.getElementById('toast');t.textContent=(type==='suc'?'✅ ':'❌ ')+msg;t.className='toast show t'+type;setTimeout(()=>t.className='toast',3000);
}

init();
</script>
</body>
</html>
