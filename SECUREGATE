<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>SECUREGATE 2.0</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
body{background:#f0f4f8;color:#1e293b;font-family:'IBM Plex Mono',monospace;min-height:100vh;font-size:13px}

/* ── LOGIN ── */
.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%)}
.login-box{background:#fff;border-radius:16px;padding:32px 28px;width:100%;max-width:360px;box-shadow:0 8px 32px #00000030}
.login-logo{text-align:center;margin-bottom:20px}
.login-logo .ico{font-size:40px;display:block;margin-bottom:6px}
.login-logo h1{font-size:16px;font-weight:700;color:#0f172a;letter-spacing:.08em}
.login-logo p{font-size:8px;color:#94a3b8;letter-spacing:.12em;margin-top:2px}
.role-select{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px}
.role-btn{border:2px solid #e2e8f0;border-radius:10px;padding:14px 8px;text-align:center;cursor:pointer;transition:.15s;background:#f8fafc}
.role-btn:hover{border-color:#0284c7;background:#e0f2fe}
.role-btn.selected{border-color:#0284c7;background:#e0f2fe}
.role-btn .ri{font-size:22px;display:block;margin-bottom:4px}
.role-btn .rn{font-size:10px;font-weight:700;color:#0f172a}
.role-btn .rd{font-size:8px;color:#64748b;margin-top:2px}
.pin-label{font-size:8px;color:#64748b;letter-spacing:.12em;margin-bottom:8px;display:block}
.pin-display{display:flex;gap:10px;justify-content:center;margin-bottom:16px}
.pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid #cbd5e1;background:#f8fafc;transition:.2s}
.pin-dot.filled{background:#0284c7;border-color:#0284c7}
.pin-pad{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}
.pin-key{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:14px;font-size:16px;font-weight:700;cursor:pointer;font-family:inherit;color:#0f172a;transition:.15s;text-align:center}
.pin-key:hover{background:#e0f2fe;border-color:#0284c7}
.pin-key:active{transform:scale(.95)}
.pin-del{background:#fff0f0;border-color:#fecaca;color:#dc2626}
.pin-del:hover{background:#fee2e2}
.login-btn{background:linear-gradient(135deg,#0284c7,#0369a1);border:none;color:#fff;padding:12px;border-radius:8px;font-size:11px;font-weight:700;font-family:inherit;width:100%;cursor:pointer}
.login-btn:disabled{opacity:.4;cursor:not-allowed}
.login-err{background:#fee2e2;border:1px solid #fca5a5;color:#dc2626;border-radius:6px;padding:8px 12px;font-size:9px;text-align:center;margin-bottom:10px;display:none}

/* ── HEADER ── */
header{background:#fff;border-bottom:1px solid #cbd5e1;padding:10px 14px;position:sticky;top:0;z-index:100;box-shadow:0 1px 4px #00000012}
.hrow1{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.logo{display:flex;align-items:center;gap:8px}
.logo-icon{width:32px;height:32px;background:linear-gradient(135deg,#0284c7,#0369a1);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.logo-text{font-size:14px;font-weight:700;letter-spacing:.08em;color:#0f172a}
.logo-sub{font-size:13px;color:#0369a1;letter-spacing:.06em;font-weight:800}
.session-info{display:flex;align-items:center;gap:8px}
.session-badge{background:#e0f2fe;border:1px solid #bae6fd;border-radius:20px;padding:3px 10px;font-size:8px;font-weight:700;color:#0284c7;display:flex;align-items:center;gap:4px}
.session-badge.admin{background:#fef3c7;border-color:#fde68a;color:#92400e}
.logout-btn{background:#f1f5f9;border:1px solid #e2e8f0;color:#64748b;padding:4px 9px;border-radius:5px;cursor:pointer;font-size:8px;font-family:inherit}
#clock{font-size:15px;font-weight:700;color:#0284c7}
#date{font-size:8px;color:#94a3b8;text-align:right}
.sync-dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:#94a3b8;margin-left:5px;vertical-align:middle}
.sync-dot.ok{background:#16a34a;box-shadow:0 0 6px #16a34a80}
.sync-dot.syncing{background:#f59e0b;animation:pulse .8s infinite}
.sync-dot.err{background:#dc2626}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
nav{display:flex;gap:5px}
.nb{flex:1;background:transparent;border:1px solid transparent;color:#94a3b8;padding:7px 2px;border-radius:6px;cursor:pointer;font-size:9px;letter-spacing:.05em;font-family:inherit;text-align:center;transition:.15s}
.nb:hover{background:#f1f5f9;color:#475569}
.nb.active{background:#e0f2fe;border-color:#bae6fd;color:#0284c7}

/* ── MAIN ── */
main{padding:14px;max-width:700px;margin:0 auto}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:18px}
.stat{background:#fff;border-radius:9px;padding:12px 14px;position:relative;overflow:hidden;box-shadow:0 1px 3px #0000000d}
.slabel{font-size:8px;color:#94a3b8;letter-spacing:.12em;margin-bottom:3px}
.sval{font-size:26px;font-weight:700;line-height:1;margin-bottom:2px}
.ssub{font-size:8px;color:#94a3b8}
.sdot{position:absolute;top:12px;right:12px;width:7px;height:7px;border-radius:50%}
.sec{font-size:10px;font-weight:700;color:#0284c7;letter-spacing:.1em;margin-bottom:12px;display:flex;align-items:center;gap:7px}
.bar{width:3px;height:13px;border-radius:2px;display:inline-block;flex-shrink:0}
.card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;margin-bottom:16px;box-shadow:0 1px 3px #0000000d}
.card-pad{padding:16px}
.tscroll{overflow-x:auto}
table{width:100%;border-collapse:collapse;min-width:420px}
th{text-align:left;padding:9px 11px;font-size:8px;color:#94a3b8;letter-spacing:.1em;border-bottom:1px solid #e2e8f0;font-weight:700;background:#f8fafc}
td{padding:10px 11px;border-bottom:1px solid #f1f5f9;vertical-align:middle;font-size:11px}
tr:last-child td{border-bottom:none}
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:20px;font-size:8px;font-weight:700}
.bdot{width:5px;height:5px;border-radius:50%}
.ben{background:#dcfce7;color:#16a34a}.ben .bdot{background:#16a34a;box-shadow:0 0 5px #16a34a80}
.beg{background:#f1f5f9;color:#64748b}.beg .bdot{background:#94a3b8}
.ttag{background:#e0f2fe;color:#0284c7;padding:2px 7px;border-radius:4px;font-size:8px;font-weight:600}
.bp{background:linear-gradient(135deg,#0284c7,#0369a1);border:none;color:#fff;padding:9px 14px;border-radius:6px;cursor:pointer;font-size:10px;font-weight:700;font-family:inherit;width:100%;margin-top:4px}
.bd{background:linear-gradient(135deg,#dc2626,#b91c1c);border:none;color:#fff;padding:9px 14px;border-radius:6px;cursor:pointer;font-size:10px;font-weight:700;font-family:inherit;width:100%;margin-top:4px}
.bs{background:linear-gradient(135deg,#16a34a,#15803d);border:none;color:#fff;padding:5px 9px;border-radius:5px;cursor:pointer;font-size:8px;font-weight:700;font-family:inherit}
.be{background:linear-gradient(135deg,#f59e0b,#d97706);border:none;color:#fff;padding:5px 9px;border-radius:5px;cursor:pointer;font-size:8px;font-weight:700;font-family:inherit}
.bg{background:#f1f5f9;border:1px solid #e2e8f0;color:#475569;padding:5px 9px;border-radius:5px;cursor:pointer;font-size:8px;font-family:inherit}
.bc{background:#fff;border:1px solid #e2e8f0;color:#64748b;padding:9px 14px;border-radius:6px;cursor:pointer;font-size:10px;font-family:inherit;width:100%;margin-top:4px}
.fg{margin-bottom:10px}
label{font-size:11px;color:#64748b;letter-spacing:.08em;display:block;margin-bottom:4px;font-weight:700}
input,select,textarea{background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;color:#1e293b;padding:9px 11px;font-size:11px;font-family:inherit;width:100%;outline:none;transition:.15s}
input:focus,select:focus,textarea:focus{border-color:#0284c7;background:#fff;box-shadow:0 0 0 3px #0284c720}
textarea{resize:vertical;min-height:56px}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:10px}
.acts{display:flex;gap:5px}
.admin-only{display:none}

/* FOTO */
.photo-sec{margin-bottom:14px}
.photo-lbl{font-size:8px;color:#64748b;letter-spacing:.12em;display:block;margin-bottom:6px}
.drop-zone{border:2px dashed #cbd5e1;border-radius:10px;background:#f8fafc;padding:18px 14px;text-align:center;transition:.2s;position:relative}
.drop-zone.drag-over{border-color:#0284c7;background:#e0f2fe}
.drop-zone.has-img{border:2px solid #0284c7;background:#fff;padding:8px}
.drop-zone .pi{font-size:26px;margin-bottom:4px}
.drop-zone p{font-size:9px;color:#64748b;margin-bottom:4px;line-height:1.5}
.drop-zone .hint{font-size:8px;color:#94a3b8;margin-top:6px}
.drop-preview{width:100%;max-height:160px;object-fit:contain;border-radius:6px;display:none}
.drop-clear{position:absolute;top:6px;right:6px;background:#fee2e2;border:none;border-radius:4px;color:#dc2626;font-size:9px;padding:3px 7px;cursor:pointer;font-family:inherit;z-index:2}
.cam-btn{background:linear-gradient(135deg,#0284c7,#0369a1);border:none;color:#fff;padding:8px 14px;border-radius:6px;cursor:pointer;font-size:9px;font-weight:700;font-family:inherit;margin-top:8px;display:inline-flex;align-items:center;gap:5px}

/* ADMIN PANEL */
.admin-section{background:#fff;border:1px solid #fde68a;border-radius:10px;padding:16px;margin-bottom:16px}
.admin-title{font-size:10px;font-weight:700;color:#92400e;letter-spacing:.1em;margin-bottom:14px;display:flex;align-items:center;gap:6px}
.pin-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.pin-row input{max-width:120px;letter-spacing:.2em;text-align:center}
.pin-row label{min-width:80px;margin:0}

/* MODAL */
.cam-mo{display:none;position:fixed;inset:0;background:#000000cc;z-index:300;align-items:center;justify-content:center}
.cam-mo.open{display:flex}
.cam-box{background:#0f172a;border-radius:14px;overflow:hidden;width:min(96vw,480px);max-height:90vh;display:flex;flex-direction:column}
.cam-head{padding:12px 16px;border-bottom:1px solid #1e3a5f;display:flex;justify-content:space-between;align-items:center;background:#0a1220}
.cam-title{font-size:11px;font-weight:700;color:#e2e8f0;letter-spacing:.06em}
#camVideo{width:100%;border-radius:8px;background:#000;max-height:55vh}
#camCanvas{display:none}
.cam-body{padding:12px;display:flex;flex-direction:column;align-items:center;gap:10px}
.cam-foot{padding:10px 16px;border-top:1px solid #1e3a5f;display:flex;gap:8px;background:#0a1220}
.cam-snap{flex:1;background:linear-gradient(135deg,#0284c7,#0369a1);border:none;color:#fff;padding:10px;border-radius:7px;font-size:10px;font-weight:700;font-family:inherit;cursor:pointer}
.cam-cancel{background:transparent;border:1px solid #334155;color:#94a3b8;padding:10px 14px;border-radius:7px;font-size:10px;font-family:inherit;cursor:pointer}
.mo{display:none;position:fixed;inset:0;background:#00000055;z-index:200;align-items:flex-end;justify-content:center}
.mo.open{display:flex}
.mbox{background:#fff;border:1px solid #e2e8f0;border-radius:12px 12px 0 0;width:100%;max-width:700px;max-height:90vh;overflow-y:auto;box-shadow:0 -4px 24px #00000018}
.mh{padding:14px 18px 12px;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;align-items:center;background:#f8fafc}
.mt{font-size:12px;font-weight:700;letter-spacing:.06em;color:#0f172a}
.mb{padding:16px 18px}
.mf{padding:12px 18px;border-top:1px solid #e2e8f0;display:flex;flex-direction:column;gap:7px;background:#f8fafc}
.toast{display:none;position:fixed;bottom:70px;left:12px;right:12px;padding:11px 16px;border-radius:8px;font-size:10px;z-index:999;text-align:center}
.toast.show{display:block}
.tsuc{background:#dcfce7;border:1px solid #86efac;color:#15803d}
.terr{background:#fee2e2;border:1px solid #fca5a5;color:#dc2626}
.dgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.di{background:#f8fafc;border:1px solid #e2e8f0;border-radius:7px;padding:11px}
.dl{font-size:8px;color:#94a3b8;letter-spacing:.12em;margin-bottom:3px}
.dv{font-size:11px;color:#1e293b;font-weight:600}
.ibox{background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:13px;margin-bottom:12px}
.cbox{background:#fefce8;border:1px solid #fde68a;border-radius:8px;padding:11px;font-size:10px;color:#92400e}
.cbox-red{background:#fff0f0;border:1px solid #fecaca;border-radius:8px;padding:11px;font-size:10px;color:#dc2626}
.sbar{display:flex;gap:7px;margin-bottom:9px}.sbar input{flex:1}
.filt{display:flex;gap:7px;margin-bottom:12px}
.filt select{flex:1;font-size:10px;padding:7px 9px}
.rcount{font-size:9px;color:#94a3b8;margin-bottom:9px}
.empty{text-align:center;color:#94a3b8;padding:24px;font-size:10px}
.id-thumb{width:36px;height:26px;object-fit:cover;border-radius:3px;border:1px solid #e2e8f0;cursor:pointer}
.loading-overlay{position:fixed;inset:0;background:#f0f4f8;z-index:500;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px}
.spinner{width:32px;height:32px;border:3px solid #e2e8f0;border-top-color:#0284c7;border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-txt{font-size:10px;color:#64748b;letter-spacing:.1em}
</style>
</head>
<body>

<!-- LOADING -->
<div class="loading-overlay" id="loader">
  <div class="logo-icon" style="width:48px;height:48px;font-size:24px;margin-bottom:4px">🛡️</div>
  <div class="spinner"></div>
  <div class="loading-txt">CARGANDO · SECUREGATE</div>
</div>

<!-- LOGIN -->
<div id="loginScreen" style="display:none">
  <div class="login-wrap">
    <div class="login-box">
      <div class="login-logo">
        <span class="ico">🛡️</span>
        <h1 style="font-size:20px;font-weight:800;letter-spacing:.08em">SECUREGATE 2.0</h1>
        <p style="font-size:13px;font-weight:800;color:#0369a1;letter-spacing:.06em;margin-top:4px">CONDOMINIO PUERTO BAHÍA</p>
      </div>
      <div class="role-select">
        <div class="role-btn selected" id="rb-user" onclick="selectRole('user')">
          <span class="ri">👮</span>
          <div class="rn">PUERTA PRINCIPAL</div>
          <div class="rd">Registrar accesos</div>
        </div>
        <div class="role-btn" id="rb-admin" onclick="selectRole('admin')">
          <span class="ri">🔧</span>
          <div class="rn">ADMINISTRADOR</div>
          <div class="rd">Control total</div>
        </div>
      </div>
      <span class="pin-label">INGRESA TU PIN</span>
      <div class="pin-display">
        <div class="pin-dot" id="pd0"></div>
        <div class="pin-dot" id="pd1"></div>
        <div class="pin-dot" id="pd2"></div>
        <div class="pin-dot" id="pd3"></div>
      </div>
      <div id="loginErr" class="login-err">PIN incorrecto. Inténtalo de nuevo.</div>
      <div class="pin-pad">
        <button class="pin-key" onclick="pinKey('1')">1</button>
        <button class="pin-key" onclick="pinKey('2')">2</button>
        <button class="pin-key" onclick="pinKey('3')">3</button>
        <button class="pin-key" onclick="pinKey('4')">4</button>
        <button class="pin-key" onclick="pinKey('5')">5</button>
        <button class="pin-key" onclick="pinKey('6')">6</button>
        <button class="pin-key" onclick="pinKey('7')">7</button>
        <button class="pin-key" onclick="pinKey('8')">8</button>
        <button class="pin-key" onclick="pinKey('9')">9</button>
        <button class="pin-key pin-del" onclick="pinDel()">⌫</button>
        <button class="pin-key" onclick="pinKey('0')">0</button>
        <button class="pin-key" onclick="pinEnter()" style="background:#e0f2fe;border-color:#bae6fd;color:#0284c7">✓</button>
      </div>
    </div>
  </div>
</div>

<!-- APP -->
<div id="appScreen" style="display:none">
<header>
  <div class="hrow1">
    <div class="logo">
      <div class="logo-icon">🛡️</div>
      <div><div class="logo-text">SECUREGATE</div><div class="logo-sub">CONTROL DE ACCESO · CONDOMINIO PUERTO BAHÍA</div></div>
    </div>
    <div style="text-align:right">
      <div id="clock" style="font-size:15px;font-weight:700;color:#0284c7">--:--</div>
      <div id="date" style="font-size:8px;color:#94a3b8"></div>
      <div style="margin-top:3px;display:flex;align-items:center;gap:6px;justify-content:flex-end">
        <span class="session-badge" id="sessionBadge">👮 GUARDIA</span>
        <span style="font-size:8px;color:#94a3b8">SYNC</span><span class="sync-dot" id="sdot"></span>
        <button class="logout-btn" onclick="logout()">Salir</button>
      </div>
    </div>
  </div>
  <nav>
    <button class="nb active" onclick="sv('dashboard')">📊 PANEL</button>
    <button class="nb" onclick="sv('registro')">📋 INGRESO</button>
    <button class="nb" onclick="sv('historial')">🗂 HISTORIAL</button>
    <button class="nb admin-only" id="navAdmin" onclick="sv('admin')">⚙️ ADMIN</button>
  </nav>
</header>

<main>
<!-- DASHBOARD -->
<div id="vd">
  <div class="grid2">
    <div class="stat" style="border-left:3px solid #16a34a"><div class="sdot" style="background:#16a34a;box-shadow:0 0 7px #16a34a80"></div><div class="slabel">EN RECINTO</div><div class="sval" style="color:#16a34a" id="s1">0</div><div class="ssub">activos</div></div>
    <div class="stat" style="border-left:3px solid #0284c7"><div class="sdot" style="background:#0284c7;box-shadow:0 0 7px #0284c780"></div><div class="slabel">INGRESOS HOY</div><div class="sval" style="color:#0284c7" id="s2">0</div><div class="ssub">entradas</div></div>
    <div class="stat" style="border-left:3px solid #7c3aed"><div class="sdot" style="background:#7c3aed;box-shadow:0 0 7px #7c3aed80"></div><div class="slabel">EGRESOS HOY</div><div class="sval" style="color:#7c3aed" id="s3">0</div><div class="ssub">salidas</div></div>
    <div class="stat" style="border-left:3px solid #ea580c"><div class="sdot" style="background:#ea580c;box-shadow:0 0 7px #ea580c80"></div><div class="slabel">TOTAL</div><div class="sval" style="color:#ea580c" id="s4">0</div><div class="ssub">registros</div></div>
  </div>
  <div class="sec"><span class="bar" style="background:#16a34a"></span>VISITANTES EN RECINTO</div>
  <div class="card"><div class="tscroll"><table><thead><tr><th>NOMBRE</th><th>TIPO</th><th>UNIDAD</th><th>HORA</th><th>ACCIÓN</th></tr></thead><tbody id="tbd"></tbody></table></div></div>
  <button class="bp" onclick="om('entrada')">+ REGISTRAR NUEVO INGRESO</button>
</div>

<!-- REGISTRO -->
<div id="vr" style="display:none">
  <div class="sec"><span class="bar" style="background:#0284c7"></span>NUEVO INGRESO</div>
  <div class="card card-pad">
    <div class="frow"><div class="fg"><label>NOMBRE COMPLETO *</label><input id="fn" placeholder="Nombre y apellido"/></div><div class="fg"><label>DOCUMENTO *</label><input id="fd" placeholder="V-12345678"/></div></div>
    <div class="frow"><div class="fg"><label>TIPO</label><select id="ft"><option>Visita</option><option>Propietario</option><option>Residente</option><option>Proveedor/Servicio</option><option>Contratista Externo</option><option>Empleado</option><option>Otro</option></select></div><div class="fg"><label>PLACA <span style="font-weight:400;color:#94a3b8;font-size:9px">(opcional)</span></label><input id="fp" placeholder="ABC-123"/></div></div>
    <div class="frow"><div class="fg"><label>TORRE / ÁREA *</label><select id="ftr"><option value="">Seleccionar...</option><option>Apartamentos Valle Alto</option><option>Apartamentos Valle</option><option>Villa Montaña</option><option>Villa Marina</option><option>Villa Playa</option><option>La Marina</option><option>Hotel Bannister</option><option>Administración HMS</option><option>Proyecto Bancalari</option><option>Otras</option></select></div><div class="fg"><label>NÚMERO DE LA PROPIEDAD <span style="font-weight:400;color:#94a3b8;font-size:9px">(opcional)</span></label><input id="fpi" placeholder="Ej. 4B"/></div></div>
